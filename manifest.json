{
  "manifest_version": 3,
  "name": "UK Visa Sponsor Checker for LinkedIn",
  "version": "1.0.0",
  "description": "Highlights LinkedIn jobs in green (UK visa sponsor) or red (not on the register), using official UK Home Office register",
  "permissions": ["storage", "alarms", "unlimitedStorage"],
  "host_permissions": [
    "https://www.gov.uk/*",
    "https://assets.publishing.service.gov.uk/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["common.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "UK Visa Sponsor Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
